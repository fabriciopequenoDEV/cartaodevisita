{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; script-src 'self' 'unsafe-inline'; frame-ancestors 'self';" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/oferta_ia_smd",
      "destination": "/oferta-ia-smd",
      "permanent": true
    },
    {
      "source": "/oferta_alocacao_smd",
      "destination": "/oferta-alocacao-smd",
      "permanent": true
    },
    {
      "source": "/oferta_gerente_de_mudancas_smd",
      "destination": "/oferta-gerente-de-mudancas-smd",
      "permanent": true
    },
    {
      "source": "/oferta_planejamento_estrategico_smd",
      "destination": "/oferta-planejamento-estrategico-smd",
      "permanent": true
    },
    {
      "source": "/cartão_fabricio",
      "destination": "/cartao_fabricio",
      "permanent": true
    },
    {
      "source": "/cartão_ricardo",
      "destination": "/cartao_ricardo",
      "permanent": true
    },
    {
      "source": "/MétodoDeIA_SMD",
      "destination": "/metodo_de_ia_smd",
      "permanent": true
    },
    {
      "source": "/estudio_da_oferta_smd",
      "destination": "/estudio-da-oferta-smd",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/index_sermaisdigital",
      "destination": "/index_sermaisdigital.html"
    },
    {
      "source": "/cartao_fabricio",
      "destination": "/cartao_fabricio.html"
    },
    {
      "source": "/cartao_ricardo",
      "destination": "/cartao_ricardo.html"
    },
    {
      "source": "/oferta-ia-smd",
      "destination": "/oferta-ia-smd.html"
    },
    {
      "source": "/oferta-alocacao-smd",
      "destination": "/oferta-alocacao-smd.html"
    },
    {
      "source": "/oferta-gerente-de-mudancas-smd",
      "destination": "/oferta-gerente-de-mudancas-smd.html"
    },
    {
      "source": "/oferta-planejamento-estrategico-smd",
      "destination": "/oferta-planejamento-estrategico-smd.html"
    },
    {
      "source": "/metodo_de_ia_smd",
      "destination": "/metodo_de_ia_smd.html"
    },
    {
      "source": "/estudio-da-oferta-smd",
